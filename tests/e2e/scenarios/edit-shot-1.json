{
  "project": {
    "name": "noir",
    "directory": "/tmp/noir.kshana"
  },
  "rules": [
    {
      "on": { "channel": "runTask", "match": "show me s1 shot 1" },
      "emit": [
        {
          "after": 50,
          "event": "tool_call",
          "data": {
            "toolCallId": "tc-create",
            "toolName": "image_text_to_image",
            "arguments": { "scene": "s1", "shot": 1 },
            "status": "in_progress"
          }
        },
        {
          "after": 200,
          "event": "tool_result",
          "data": { "toolCallId": "tc-create", "isError": false }
        },
        {
          "after": 230,
          "event": "media_generated",
          "data": {
            "kind": "image",
            "path": "/tmp/noir.kshana/.kshana/cache/s1_shot_1_v1.png",
            "project": "noir"
          }
        },
        {
          "after": 280,
          "event": "agent_response",
          "data": {
            "output": "Here is **s1 shot 1**.",
            "status": "completed"
          }
        }
      ]
    },
    {
      "on": { "channel": "runTask", "match": "make it darker" },
      "emit": [
        {
          "after": 50,
          "event": "tool_call",
          "data": {
            "toolCallId": "tc-edit",
            "toolName": "image_edit",
            "arguments": {
              "instruction": "make it darker and more cinematic",
              "source": "s1_shot_1_v1.png"
            },
            "status": "in_progress"
          }
        },
        {
          "after": 200,
          "event": "tool_result",
          "data": { "toolCallId": "tc-edit", "isError": false }
        },
        {
          "after": 230,
          "event": "media_generated",
          "data": {
            "kind": "image",
            "path": "/tmp/noir.kshana/.kshana/cache/s1_shot_1_v2.png",
            "project": "noir"
          }
        },
        {
          "after": 280,
          "event": "agent_response",
          "data": {
            "output": "Updated **s1 shot 1** — darker tones, deeper shadows.",
            "status": "completed"
          }
        }
      ]
    }
  ]
}
