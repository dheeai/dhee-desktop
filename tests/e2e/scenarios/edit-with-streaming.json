{
  "project": {
    "name": "noir",
    "directory": "/tmp/noir.kshana"
  },
  "rules": [
    {
      "on": { "channel": "runTask", "match": "show me s1 shot 1" },
      "emit": [
        {
          "after": 50,
          "event": "tool_call",
          "data": {
            "toolCallId": "tc-create",
            "toolName": "image_text_to_image",
            "arguments": { "scene": "s1", "shot": 1 }
          }
        },
        {
          "after": 180,
          "event": "tool_result",
          "data": { "toolCallId": "tc-create", "isError": false }
        },
        {
          "after": 200,
          "event": "media_generated",
          "data": {
            "kind": "image",
            "path": "/tmp/noir.kshana/.kshana/cache/v1.png",
            "project": "noir"
          }
        },
        {
          "after": 240,
          "event": "agent_response",
          "data": { "output": "Created v1.", "status": "completed" }
        }
      ]
    },
    {
      "on": { "channel": "runTask", "match": "make it more dramatic" },
      "emit": [
        {
          "after": 50,
          "event": "stream_chunk",
          "data": { "content": "Analyzing the source frame" }
        },
        {
          "after": 100,
          "event": "stream_chunk",
          "data": { "content": " — looking at composition" }
        },
        {
          "after": 150,
          "event": "stream_chunk",
          "data": { "content": " and key light placement…" }
        },
        {
          "after": 200,
          "event": "tool_call",
          "data": {
            "toolCallId": "tc-edit",
            "toolName": "image_edit",
            "arguments": {
              "instruction": "more dramatic chiaroscuro",
              "source": "v1.png"
            }
          }
        },
        {
          "after": 350,
          "event": "tool_result",
          "data": { "toolCallId": "tc-edit", "isError": false }
        },
        {
          "after": 380,
          "event": "media_generated",
          "data": {
            "kind": "image",
            "path": "/tmp/noir.kshana/.kshana/cache/v2_dramatic.png",
            "project": "noir"
          }
        },
        {
          "after": 430,
          "event": "agent_response",
          "data": {
            "output": "**Done.** Pushed contrast and tightened the key light.",
            "status": "completed"
          }
        }
      ]
    }
  ]
}
