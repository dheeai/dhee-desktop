{
  "name": "dhee-desktop",
  "version": "1.1.3",
  "description": "Desktop application for Dhee Studios video generation",
  "keywords": [
    "dhee",
    "electron",
    "react",
    "video-generation",
    "ai"
  ],
  "homepage": "https://github.com/dheeai/dhee-desktop#readme",
  "bugs": {
    "url": "https://github.com/dheeai/dhee-desktop/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dheeai/dhee-desktop.git"
  },
  "license": "MIT",
  "author": {
    "name": "Dhee Studios",
    "email": "contact@dhee.ai",
    "url": "https://dhee.ai"
  },
  "contributors": [],
  "main": "./.erb/dll/main.bundle.dev.js",
  "scripts": {
    "build": "concurrently \"npm run build:main\" \"npm run build:renderer\"",
    "build:dll": "cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS=\"-r ts-node/register --no-warnings\" webpack --config ./.erb/configs/webpack.config.renderer.dev.dll.ts",
    "build:main": "cross-env NODE_ENV=production TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS=\"-r ts-node/register --no-warnings\" webpack --config ./.erb/configs/webpack.config.main.prod.ts",
    "build:renderer": "cross-env NODE_ENV=production TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS=\"-r ts-node/register --no-warnings\" webpack --config ./.erb/configs/webpack.config.renderer.prod.ts",
    "prepare:whisper-model": "node ./.erb/scripts/prepare-whisper-model.js",
    "prepare:remotion-browser": "node ./.erb/scripts/prepare-remotion-browser.js",
    "prepare:desktop-runtime": "npm run prepare:whisper-model && npm run prepare:remotion-browser",
    "verify:dhee-core": "ts-node ./.erb/scripts/verify-dhee-core.ts",
    "ensure:dhee-core-dist": "node .erb/scripts/ensure-dhee-core-dist.js",
    "prepare:app-deps": "ts-node ./.erb/scripts/install-app-deps.ts",
    "postinstall": "ts-node .erb/scripts/check-native-dep.js && node .erb/scripts/ensure-dhee-core-dist.js && node .erb/scripts/conditional-install-app-deps.js && npm run build:dll",
    "lint": "cross-env NODE_ENV=development eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "cross-env NODE_ENV=development eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "package": "npm run verify:dhee-core && npm run prepare:desktop-runtime && ts-node ./.erb/scripts/clean.js dist && npm run prepare:app-deps && npm run build && electron-builder build --mac --win --publish never && npm run build:dll",
    "package:mac": "npm run verify:dhee-core && npm run prepare:desktop-runtime && ts-node ./.erb/scripts/clean.js dist && npm run prepare:app-deps && npm run build && electron-builder build --mac --arm64 --publish never && npm run build:dll",
    "package:win": "npm run verify:dhee-core && npm run prepare:desktop-runtime && ts-node ./.erb/scripts/clean.js dist && npm run prepare:app-deps && npm run build && electron-builder build --win --publish never && npm run build:dll",
    "package:linux": "npm run verify:dhee-core && npm run prepare:desktop-runtime && ts-node ./.erb/scripts/clean.js dist && npm run prepare:app-deps && npm run build && electron-builder build --linux --publish never && npm run build:dll",
    "package:all": "npm run verify:dhee-core && npm run prepare:desktop-runtime && ts-node ./.erb/scripts/clean.js dist && npm run prepare:app-deps && npm run build && electron-builder build --mac --win --publish never && npm run build:dll",
    "release": "npm run verify:dhee-core && npm run prepare:desktop-runtime && ts-node ./.erb/scripts/clean.js dist && npm run prepare:app-deps && npm run build && electron-builder build --publish always",
    "rebuild": "electron-rebuild --parallel --types prod,dev,optional --module-dir release/app",
    "prestart": "cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS=\"-r ts-node/register --no-warnings\" webpack --config ./.erb/configs/webpack.config.main.dev.ts",
    "dev": "npm start",
    "start": "ts-node ./.erb/scripts/check-port-in-use.js && npm run prestart && npm run start:renderer",
    "start:main": "concurrently -k -P \"cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true webpack --watch --config ./.erb/configs/webpack.config.main.dev.ts\" \"electronmon . -- {@}\" --",
    "start:preload": "cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS=\"-r ts-node/register --no-warnings\" webpack --config ./.erb/configs/webpack.config.preload.dev.ts",
    "start:renderer": "cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS=\"-r ts-node/register --no-warnings\" webpack serve --config ./.erb/configs/webpack.config.renderer.dev.ts",
    "start:test-renderer": "cross-env NODE_ENV=development dhee_TEST_BRIDGE=1 TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS=\"-r ts-node/register --no-warnings\" webpack serve --config ./.erb/configs/webpack.config.renderer.dev.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test": "jest"
  },
  "browserslist": [
    "defaults"
  ],
  "prettier": {
    "singleQuote": true,
    "overrides": [
      {
        "files": [
          ".prettierrc",
          ".eslintrc"
        ],
        "options": {
          "parser": "json"
        }
      }
    ]
  },
  "jest": {
    "moduleDirectories": [
      "node_modules",
      "release/app/node_modules",
      "src"
    ],
    "moduleFileExtensions": [
      "js",
      "jsx",
      "ts",
      "tsx",
      "json"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1",
      "^react$": "<rootDir>/node_modules/react",
      "^react-dom$": "<rootDir>/node_modules/react-dom",
      "^react/jsx-runtime$": "<rootDir>/node_modules/react/jsx-runtime.js",
      "^react-markdown$": "<rootDir>/.erb/mocks/reactMarkdownMock.tsx",
      "^remark-gfm$": "<rootDir>/.erb/mocks/reactMarkdownMock.tsx",
      "^react-syntax-highlighter$": "<rootDir>/.erb/mocks/reactMarkdownMock.tsx",
      "^react-syntax-highlighter/dist/esm/styles/prism$": "<rootDir>/.erb/mocks/fileMock.js",
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/.erb/mocks/fileMock.js",
      "\\.(css|less|sass|scss)$": "identity-obj-proxy"
    },
    "setupFiles": [
      "./.erb/scripts/check-build-exists.ts"
    ],
    "testEnvironment": "jsdom",
    "testEnvironmentOptions": {
      "url": "http://localhost/"
    },
    "testPathIgnorePatterns": [
      "release/app/dist",
      ".erb/dll",
      "tests/e2e",
      "dhee-core/",
      "assets/whisper-runtime/",
      "release/build/"
    ],
    "transform": {
      "\\.(ts|tsx|js|jsx)$": "ts-jest"
    }
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.38.8",
    "@electron/notarize": "^3.0.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@react-three/fiber": "^9.5.0",
    "@remotion/bundler": "4.0.409",
    "@remotion/captions": "4.0.409",
    "@remotion/fonts": "4.0.409",
    "@remotion/gif": "4.0.409",
    "@remotion/google-fonts": "4.0.409",
    "@remotion/install-whisper-cpp": "4.0.409",
    "@remotion/layout-utils": "4.0.409",
    "@remotion/lottie": "4.0.409",
    "@remotion/media": "4.0.409",
    "@remotion/renderer": "4.0.409",
    "@remotion/three": "4.0.409",
    "@remotion/transitions": "4.0.409",
    "@remotion/zod-types": "4.0.409",
    "@ts-ffmpeg/fluent-ffmpeg": "^2.2.6",
    "@turf/turf": "^6.5.0",
    "archiver": "^7.0.1",
    "archiver-utils": "^5.0.2",
    "chokidar": "^5.0.0",
    "electron-debug": "^4.1.0",
    "electron-log": "^5.3.2",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "dhee-core": "file:../dhee-core",
    "lucide-react": "^0.555.0",
    "mapbox-gl": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.1.0",
    "react-resizable-panels": "^3.0.6",
    "react-router-dom": "^7.3.0",
    "react-syntax-highlighter": "^16.1.0",
    "remark-gfm": "^4.0.1",
    "remotion": "4.0.409",
    "three": "^0.183.1",
    "zod": "3.22.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@playwright/test": "^1.59.1",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.15",
    "@svgr/webpack": "^8.1.0",
    "@teamsupercell/typings-for-css-modules-loader": "^2.5.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/archiver": "^7.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "22.13.10",
    "@types/react": "^19.0.11",
    "@types/react-dom": "^19.0.4",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/react-test-renderer": "^19.0.0",
    "@types/webpack-bundle-analyzer": "^4.7.0",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "browserslist-config-erb": "^0.0.3",
    "chalk": "^4.1.2",
    "concurrently": "^9.1.2",
    "core-js": "^3.41.0",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.2",
    "detect-port": "^2.1.0",
    "electron": "^35.0.2",
    "electron-builder": "^25.1.8",
    "electron-devtools-installer": "^4.0.0",
    "electronmon": "^2.0.3",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-erb": "^4.1.0",
    "eslint-import-resolver-typescript": "^4.1.1",
    "eslint-import-resolver-webpack": "^0.13.10",
    "eslint-plugin-compat": "^6.0.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.6.3",
    "http-server": "^14.1.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "mini-css-extract-plugin": "^2.9.2",
    "node-addon-api": "^8.5.0",
    "node-gyp": "^11.2.0",
    "prettier": "^3.5.3",
    "react-refresh": "^0.16.0",
    "react-test-renderer": "^19.0.0",
    "rimraf": "^6.0.1",
    "sass": "^1.86.0",
    "sass-loader": "^16.0.5",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.3.14",
    "ts-jest": "^29.2.6",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^5.8.2",
    "url-loader": "^4.1.1",
    "webpack": "^5.98.0",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0",
    "webpack-merge": "^6.0.1"
  },
  "overrides": {
    "node-addon-api": "^8.5.0",
    "node-abi": "^4.28.0",
    "node-gyp": "^11.2.0",
    "@electron/rebuild": "^3.7.1"
  },
  "build": {
    "productName": "Dhee",
    "appId": "com.dheeai.desktop",
    "asar": true,
    "afterSign": ".erb/scripts/notarize.js",
    "afterAllArtifactBuild": ".erb/scripts/stable-release-artifacts.cjs",
    "asarUnpack": [
      "**\\*.{node,dll}",
      "**/node_modules/@ffmpeg-installer/**",
      "**/node_modules/@esbuild/**",
      "**/node_modules/react/**",
      "**/node_modules/react-dom/**",
      "**/node_modules/react-refresh/**",
      "**/node_modules/@react-three/**",
      "**/node_modules/@babel/runtime/**",
      "**/node_modules/base64-js/**",
      "**/node_modules/buffer/**",
      "**/node_modules/its-fine/**",
      "**/node_modules/react-use-measure/**",
      "**/node_modules/scheduler/**",
      "**/node_modules/suspend-react/**",
      "**/node_modules/use-sync-external-store/**",
      "**/node_modules/execa/**",
      "**/node_modules/extract-zip/**",
      "**/node_modules/mediabunny/**",
      "**/node_modules/remotion/**",
      "**/node_modules/source-map/**",
      "**/node_modules/three/**",
      "**/node_modules/ws/**",
      "**/node_modules/zod/**",
      "**/node_modules/zustand/**",
      "**/node_modules/@remotion/**",
      "**/node_modules/webpack/**",
      "**/node_modules/webpack-sources/**",
      "**/node_modules/enhanced-resolve/**",
      "**/node_modules/tapable/**",
      "**/node_modules/terser-webpack-plugin/**",
      "**/node_modules/css-loader/**",
      "**/node_modules/style-loader/**",
      "**/node_modules/.pnpm/@remotion+bundler*/**",
      "**/node_modules/.pnpm/@react-three+fiber@*/**",
      "**/node_modules/.pnpm/@babel+runtime@*/**",
      "**/node_modules/.pnpm/base64-js@*/**",
      "**/node_modules/.pnpm/buffer@*/**",
      "**/node_modules/.pnpm/execa@*/**",
      "**/node_modules/.pnpm/extract-zip@*/**",
      "**/node_modules/.pnpm/its-fine@*/**",
      "**/node_modules/.pnpm/mediabunny@*/**",
      "**/node_modules/.pnpm/react-use-measure@*/**",
      "**/node_modules/.pnpm/react-refresh@*/**",
      "**/node_modules/.pnpm/source-map@*/**",
      "**/node_modules/.pnpm/suspend-react@*/**",
      "**/node_modules/.pnpm/use-sync-external-store@*/**",
      "**/node_modules/.pnpm/webpack@*/**",
      "**/node_modules/.pnpm/webpack-sources@*/**",
      "**/node_modules/.pnpm/ws@*/**",
      "**/node_modules/.pnpm/zustand@*/**",
      "**/node_modules/.pnpm/enhanced-resolve@*/**",
      "**/node_modules/.pnpm/tapable@*/**",
      "**/node_modules/.pnpm/terser-webpack-plugin@*/**",
      "**/node_modules/.pnpm/css-loader@*/**",
      "**/node_modules/.pnpm/style-loader@*/**",
      "**/node_modules/@turf/**",
      "**/node_modules/mapbox-gl/**",
      "**/node_modules/dhee-core/**",
      "**/node_modules/fastify/**",
      "**/node_modules/@fastify/**",
      "**/node_modules/openai/**",
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/sharp/**",
      "**/node_modules/dotenv/**",
      "**/node_modules/eventemitter3/**",
      "**/node_modules/uuid/**",
      "**/node_modules/nanoid/**",
      "**/node_modules/**/*"
    ],
    "files": [
      "dist",
      "node_modules",
      "package.json",
      ".dhee-core-version.json"
    ],
    "mac": {
      "notarize": false,
      "target": {
        "target": "default",
        "arch": [
          "arm64",
          "x64"
        ]
      },
      "type": "distribution",
      "hardenedRuntime": true,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    },
    "directories": {
      "app": "release/app",
      "buildResources": "assets",
      "output": "release/build"
    },
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*",
          "!**/.git/**"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "dheeai",
      "repo": "dhee-desktop",
      "releaseType": "release"
    }
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=14.x",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=7.x",
      "onFail": "error"
    }
  },
  "electronmon": {
    "patterns": [
      "!**/**",
      "src/main/**",
      ".erb/dll/**"
    ],
    "logLevel": "quiet"
  }
}
