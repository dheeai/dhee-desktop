<!DOCTYPE html>
<!--
  Preset the official theme on the root element so the very first paint
  uses the Cinematic palette. Without this, first paint falls through to
  the bare `:root` block (studio-neutral blue) until AppSettingsContext
  applies the theme via JS — producing a blue flash before the warm-black
  UI loads. Must stay in sync with DEFAULT_THEME_ID in themes.ts.
-->
<html data-theme="cinematic">
  <head>
    <meta charset="utf-8" />
    <meta
      http-equiv="Content-Security-Policy"
      content="script-src 'self' 'unsafe-inline'"
    />
    <title>Dhee Studio</title>
    <!--
      Brand font for the wordmark only (top-bar "Dhee Studio" + empty
      state title). Body text continues to use the system stack from
      tokens.scss. Italic serif gives the brand a distinct character
      from the rest of the UI chrome. Fallbacks (Georgia, serif) cover
      offline launches and CSP blocks.
    -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,300..900,0..100;1,9..144,300..900,0..100&family=Instrument+Sans:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div id="root"></div>
  </body>
</html>
